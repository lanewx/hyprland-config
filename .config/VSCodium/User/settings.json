{
	// WINDOW
	"window.commandCenter": false,
	"window.menuBarVisibility": "compact",
	"window.openFilesInNewWindow": "off",
	"window.title": "${activeEditorLong}",

	// WORKBENCH (UI)
	"workbench.activityBar.location": "hidden",
	"workbench.editor.highlightModifiedTabs": true,
	"workbench.editor.labelFormat": "short",
	"workbench.editor.pinnedTabSizing": "compact",
	"workbench.iconTheme": "vscode-jetbrains-icon-theme-2023-dark",
	"workbench.sideBar.location": "right",
	// "workbench.statusBar.visible": false,
	"workbench.tree.indent": 18,

	"workbench.colorCustomizations": {
		"menu.separatorBackground": "#0000",
		"statusBar.border": "#0000",
		"tab.border": "#0000",
	},

	// EDITOR — CORE
	"editor.bracketPairColorization.enabled": true,
	"editor.folding": true,
	"editor.inlineSuggest.enabled": true,
	"editor.insertSpaces": true,
	"editor.minimap.enabled": false,
	"editor.quickSuggestions": {
		"comments": true,
		"other": true,
		"strings": true,
	},
	"editor.renderWhitespace": "selection",
	"editor.semanticHighlighting.enabled": true,
	"editor.showFoldingControls": "always",
	"editor.smoothScrolling": true,
	"editor.stickyScroll.enabled": true,
	"editor.suggestSelection": "first",
	"editor.wordWrap": "on",
	"editor.wrappingIndent": "same",

	// EDITOR — CURSOR & SCROLL
	"editor.cursorBlinking": "smooth",
	"editor.cursorSmoothCaretAnimation": "on",
	"editor.scrollbar.horizontalScrollbarSize": 8,
	"editor.scrollbar.verticalScrollbarSize": 8,

	// EDITOR — FONT
	"editor.fontFamily": "JetBrainsMono Nerd Font, SF Mono, MonoLisa, monospace",
	"editor.fontLigatures": true,
	"editor.fontSize": 16,
	"editor.lineHeight": 25,

	"editor.codeLensFontFamily": "JetBrainsMono Nerd Font",
	"editor.inlayHints.fontFamily": "JetBrainsMono Nerd Font",
	"editor.inlineSuggest.fontFamily": "JetBrainsMono Nerd Font",

	"chat.editor.fontFamily": "JetBrainsMono Nerd Font",
	"debug.console.fontFamily": "JetBrainsMono Nerd Font",
	"errorLens.fontFamily": "JetBrainsMono Nerd Font",
	"terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
	"terminal.integrated.fontSize": 15,

	// BREADCRUMBS
	"breadcrumbs.enabled": true,
	"breadcrumbs.showClasses": true,
	"breadcrumbs.showFiles": false,
	"breadcrumbs.showMethods": true,

	// EXPLORER
	"explorer.autoReveal": true,
	"explorer.compactFolders": false,
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.confirmPasteNative": true,
	"explorer.decorations.badges": true,
	"explorer.decorations.colors": true,
	"explorer.fileNesting.enabled": true,
	"explorer.sortOrder": "type",

	// FILES
	"files.autoSave": "afterDelay",
	"files.autoSaveDelay": 1500,
	"files.eol": "\n",
	"files.insertFinalNewline": true,
	"files.trimTrailingWhitespace": true,

	// FORMATTING
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.formatOnSave": true,
	"editor.codeActionsOnSave": {
		"source.fixAll": "explicit",
		"source.organizeImports": "explicit",
	},
	"[json]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode",
	},
	"prettier.arrowParens": "avoid",
	"prettier.bracketSpacing": true,
	"prettier.enable": true,
	"prettier.semi": false,
	"prettier.singleQuote": false,
	"prettier.trailingComma": "all",
	"prettier.useTabs": true,

	// CSPELL
	// "cSpell.allowCompoundWords": true,
	// "cSpell.enabled": true,
	// "cSpell.language": "en,ru",

	// GIT / GITLENS
	"git.allowForcePush": true,
	"git.allowNoVerifyCommit": true,
	"git.autofetch": true,
	"git.decorations.enabled": true,
	"git.enableSmartCommit": true,
	"git.mergeEditor": true,
	"git.openRepositoryInParentFolders": "never",

	"gitlens.currentLine.enabled": true,
	"gitlens.graph.dimMergeCommits": true,
	"gitlens.graph.showRemoteNames": true,
	"gitlens.hovers.currentLine.over": "line",
	"gitlens.mode.statusBar.alignment": "left",
	"gitlens.views.repositories.showIncomingActivity": true,

	// ERROR LENS
	"errorLens.enabled": true,
	"errorLens.enabledDiagnosticLevels": ["error", "warning", "info"],
	"errorLens.messageTemplate": "$source: $message",
	"errorLens.removeLinebreaks": true,

	// SECURITY
	"security.workspace.trust.untrustedFiles": "open",
	"workbench.colorTheme": "Experimental Dark",

	// "files.readonlyInclude": {
	// 	"**/.cargo/registry/src/**/*.rs": true,
	// 	"**/.cargo/git/checkouts/**/*.rs": true,
	// 	"**/lib/rustlib/src/rust/library/**/*.rs": true,
	// },
}
